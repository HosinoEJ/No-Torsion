<section class="map-stats-grid">
    <div class="div map-stat-card map-stat-card--wide">
        <div class="map-stat-card__content">
            <strong class="map-stat-card__title"><%= t('map.stats.lastSynced') %></strong>
            <small class="map-stat-card__hint"><%= t('map.stats.updateNotice', { seconds: 300, minutes: 5 }) %></small>
        </div>
        <span id="lastSynced" class="map-stat-card__value map-stat-card__value--badge"><%= t('common.loading') %></span>
    </div>

    <div class="div map-stat-card map-stat-card--chart map-stat-card--submitted">
        <strong class="map-stat-card__title"><%= t('map.stats.submittedForms') %></strong>
        <div class="map-stat-card__chart">
            <div class="map-stat-card__chart-inner">
                <canvas id="updatedForm"></canvas>
            </div>
        </div>
    </div>

    <div class="div map-stat-card map-stat-card--chart map-stat-card--province">
        <strong class="map-stat-card__title"><%= t('map.stats.provinceStats') %></strong>
        <div class="map-stat-card__chart">
            <div class="map-stat-card__chart-inner">
                <canvas id="prov"></canvas>
            </div>
        </div>
    </div>

    <div class="div map-stat-card map-stat-card--compact">
        <strong class="map-stat-card__title"><%= t('map.stats.averageAge') %></strong>
        <span id="avgAge" class="map-stat-card__value map-stat-card__value--age"><%= t('common.loading') %></span>
    </div>
</section>
